{
  "name": "aws-re-hana-counter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "bun test",
    "typecheck": "tsc -b && tsc -p test/tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "preview": "bun run build && vite preview",
    "build:server": "rm -rf dist/lambda && bun build backend/lambda.ts --target=node --format=cjs --outdir=dist/lambda --external=@aws-sdk/client-dynamodb --external=@aws-sdk/lib-dynamodb --external=@aws-sdk/client-ssm && cp -r dist/client dist/lambda/client",
    "cdk": "cdk",
    "cdk:synth": "cdk synth",
    "cdk:diff": "cdk diff",
    "deploy": "bun run build && bun run build:server && cdk deploy",
    "destroy": "cdk destroy"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.500.0",
    "@aws-sdk/client-ssm": "^3.500.0",
    "@aws-sdk/lib-dynamodb": "^3.500.0",
    "hono": "^4.12.25",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "^20.10.2",
    "@hono/vite-dev-server": "^0.18.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "aws-cdk": "^2.170.0",
    "aws-cdk-lib": "^2.170.0",
    "aws-sdk-client-mock": "^4.1.0",
    "constructs": "^10.4.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
